# Yard Guard email endpoint — server-side only. NEVER prefix these with VITE_
# and never commit the real values (this file is a template; copy to .env).

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives the leads (Michael)
LEAD_NOTIFY_EMAIL=michael@ygtoronto.com

# Verified sender in Resend (must be on a verified domain for good deliverability)
FROM_EMAIL=YardGuard Quotes <quotes@ygtoronto.com>

# The public site origin, for CORS. Use "*" only if the endpoint is same-origin.
ALLOWED_ORIGIN=https://ygtoronto.com

# Port to listen on
PORT=3000
