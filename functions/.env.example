# DigitalOcean Functions env — used by `doctl serverless deploy` to fill the
# ${...} placeholders in project.yml. Copy to functions/.env (gitignored) and
# fill in real values. These are server-side only; never exposed to the browser.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox(es) that receive the leads. Comma-separate for multiple:
#   LEAD_NOTIFY_EMAIL=michael@ygtoronto.com, andrew@me.com
LEAD_NOTIFY_EMAIL=michael@ygtoronto.com

FROM_EMAIL=YardGuard Quotes <quotes@ygtoronto.com>
ALLOWED_ORIGIN=https://ygtoronto.com

# NOTE: optional CC (visible copy) and BCC (blind copy) recipients are set in
# project.yml (not here), because doctl can't substitute empty .env values.
# See LEAD_CC_EMAIL / LEAD_BCC_EMAIL under `environment:` in project.yml.
